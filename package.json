{
  "name": "morpho-vault-manager",
  "version": "0.2.0",
  "description": "Native OpenClaw plugin for onboarding and running a Morpho vault manager agent.",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.12",
      "minGatewayVersion": "2026.4.12"
    },
    "build": {
      "openclawVersion": "2026.4.12",
      "pluginSdkVersion": "2026.4.12"
    }
  },
  "files": [
    "dist/index.js",
    "dist/src/cli/**/*",
    "dist/src/lib/**/*",
    "!dist/src/lib/fixtures.js",
    "dist/src/bin/rebalance.js",
    "openclaw.plugin.json",
    "scripts/rebalance/**/*",
    "scripts/common.sh",
    "README.md",
    "SECURITY.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run -s build",
    "prepack": "npm run -s clean && npm run -s build",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^14.0.1",
    "openclaw": "2026.4.12",
    "table": "^6.9.0",
    "viem": "^2.38.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
