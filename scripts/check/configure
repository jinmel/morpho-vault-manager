#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"

log "checking configure prerequisites"
require_cmd openclaw
require_cmd ows
require_cmd bunx

if ! bunx --package @morpho-org/cli morpho health-check >/dev/null 2>&1; then
  die "morpho-cli health-check failed"
fi

log "configure prerequisites passed"
