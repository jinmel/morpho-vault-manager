#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"

log "checking policy harness expectations"

[[ -f "$ROOT_DIR/SECURITY.md" ]] || die "SECURITY.md is missing"
[[ -f "$ROOT_DIR/docs/SPEC.md" ]] || die "product spec is missing"

grep -q "OWS API token" "$ROOT_DIR/SECURITY.md" || die "security doc no longer states API-token-only model"
grep -q "OWS default policy behavior" "$ROOT_DIR/SECURITY.md" || die "security doc no longer states the default-OWS-policy model"

log "policy harness checks passed"
