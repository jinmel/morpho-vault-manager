#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"

ensure_tmp_dirs

PROFILE_ID="${VAULT_MANAGER_PROFILE:-default}"

log "running rebalance dry-run for profile ${PROFILE_ID}"

npx tsx "$ROOT_DIR/src/bin/rebalance.ts" dry-run --profile "$PROFILE_ID"
