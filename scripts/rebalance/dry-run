log "1. load profile"
log "2. read current wallet + Morpho state"
log "3. compute target allocation"
log "4. prepare transactions"
log "5. verify simulation"
log "6. return plan without signing"

cat <<'EOF'
{
  "mode": "dry-run",
  "status": "stub",
  "next": [
    "load profile config",
    "integrate OWS wallet lookup",
    "integrate morpho-cli reads and prepare flows",
    "return deterministic rebalance plan"
  ]
}
EOF
