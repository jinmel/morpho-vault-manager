#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"

ensure_tmp_dirs

if [[ "${VAULT_MANAGER_ALLOW_LIVE:-0}" != "1" ]]; then
  die "live execution is disabled. Set VAULT_MANAGER_ALLOW_LIVE=1 only in a controlled environment."
fi

PROFILE_ID="${VAULT_MANAGER_PROFILE:-default}"

log "running live rebalance for profile ${PROFILE_ID}"

node "$ROOT_DIR/dist/src/bin/rebalance.js" live --profile "$PROFILE_ID" --allow-live
