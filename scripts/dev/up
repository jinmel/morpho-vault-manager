#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"

ensure_tmp_dirs

log "bootstrapping local harness prerequisites"
require_cmd git
require_cmd node
require_cmd npm
require_cmd npx

log "delegating health reporting to scripts/dev/doctor"
exec "$SCRIPT_DIR/doctor" "$@"
